#!/usr/bin/env script.js

import { buildSpecText } from './src/completion'

// Manual tests

$.global`
alias e="echo 1"
`

app.cmd('spec', 'Print carapace completion spec').add(() => {
  const result = buildSpecText(app)
  if (result) {
    console.log(result.text)
  }
})

app
  .cmd()
  .add('<rest>', 'Rest', ['b', 'c'])
  .add('--rest1')
  .add((rest, options) => {
    console.log('rest', rest, options)
  })

app
  .cmd('ask | a', 'Ask something')
  .add('--ask-1')
  .add((name: string, options: any, context: any) => {
    $`e 2`
    console.log({
      name,
      options,
      context,
    })
  })

app.cmd('greeting formal', 'Use formal greeting style')

app.cmd('ask history', 'Show question history')

app.cmd('ask clear', 'Clear saved answers')
