#!/usr/bin/env script.js

$.global`
alias e="echo 1"
`

// Test
app.cmd('tw', 'Run tests in watch mode').add(({ argv }) => {
  $`bun run test:watch ${argv}`
})

app.cmd('t', 'Run tests once').add(({ argv }) => {
  $`bun run test ${argv}`
})

app.cmd('l', 'Run lint').add(({ argv }) => {
  $`bun run lint ${argv}`
})

// Manual tests

app
  .cmd('ask | a', 'Ask something')
  .add((name: string, options: any, context: any) => {
    $`e 2`
    console.log({
      name,
      options,
      context,
    })
  })

app.cmd('ask history', 'Show question history')
app.cmd('ask clear', 'Clear saved answers')
app.cmd('greeting formal', 'Use formal greeting style')
